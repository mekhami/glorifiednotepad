# Production Environment Variables
# Copy this file to .env.prod on your server and fill in the values
# DO NOT commit .env.prod to version control!

# Generate with: mix phx.gen.secret
export SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_MIX_PHX_GEN_SECRET

# Start the Phoenix server
export PHX_SERVER=true

# Port for Phoenix to listen on (nginx will proxy to this)
export PORT=4000

# Database path (SQLite)
export DATABASE_PATH=/var/lib/indie/indie_prod.db

# Your domain name
export PHX_HOST=glorifiednotepad.net

# Optional: Pool size for database connections
export POOL_SIZE=5
